[app]

title = Bharat AI
package.name = bharatai
package.domain = org.bharatai

source.dir = .
source.include_exts = py,png,jpg,jpeg,kv,atlas

version = 1.0

requirements = python3,kivy,cython

orientation = portrait
fullscreen = 0

log_level = 2

android.api = 33
