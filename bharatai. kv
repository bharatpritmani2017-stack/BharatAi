<ChatScreen>:
    orientation: "vertical"
    padding: 10
    spacing: 10

    ScrollView:
        TextInput:
            id: chat_output
            text: "⚡ Bharat AI Ready"
            readonly: True
            multiline: True
            size_hint_y: None
            height: max(self.minimum_height, 1200)

    BoxLayout:
        size_hint_y: None
        height: "50dp"
        spacing: 10

        TextInput:
            id: user_input
            hint_text: "Message likho..."
            multiline: False
            on_text_validate: root.send_message()

        Button:
            text: "Send"
            size_hint_x: 0.25
            on_release: root.send_message()